# ---- Telegram (control panel) ----
# Get API_ID / API_HASH from https://my.telegram.org
API_ID=
API_HASH=
# Create a bot with @BotFather and paste its token here
BOT_TOKEN=
# Your numeric Telegram user id (admin). Get it from @userinfobot
OWNER_ID=
# The report/log group id (add the bot to that group first)
LOG_GROUP_ID=

# ---- Sending behaviour ----
# Delay between each send, in seconds. Allowed range: 0.2 - 10
SEND_DELAY=1.0
# Marker placed at the END of the caption of the message in your Rubika Saved Messages.
# The bot finds that marked message and forwards it to your contacts.
FORWARD_MARKER=کد135
# Stop the whole send after this many failed sends
MAX_ERRORS=3
# Version label shown in the "Online" startup log; bump it on each update
VERSION=V1


# =========================================================================== #
# Worker subsystem (OPTIONAL). Leave as-is to run as a single server.
# =========================================================================== #
# Run mode: "master" (the Telegram panel) or "worker" (headless API node).
# On a worker server the master sets this automatically; leave it "master" here.
MODE=master

# Encryption key for worker SSH passwords/tokens stored in the DB.
# REQUIRED before you can add a worker. Generate once with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WORKER_SECRET=

# Should the master machine itself also act as a (local) worker? (recommended)
MASTER_AS_WORKER=true

# Git repo the master clones onto a worker during provisioning.
GIT_REPO_URL=https://github.com/Shantae86525/Rubika_Runway
GIT_BRANCH=main

# Worker API port (loopback-only on the worker; reached via SSH tunnel).
WORKER_API_PORT=8765
# On a WORKER server only: the bearer token the API expects (auto-set by master).
WORKER_API_TOKEN=

# Health check: workers GET this Rubika upload endpoint (200/404=ok, 503=blocked)
HEALTH_URL=https://upmessenger490.iranlms.ir/UploadFile.ashx
# How often (seconds) to post the "STATU WORKER ALL" report. 1800 = 30 min.
HEALTH_INTERVAL=1800
# Ping colour thresholds (ms): <=GREEN green, <=YELLOW yellow, else/blocked red
PING_GREEN_MS=800
PING_YELLOW_MS=2000

# All log timestamps use this timezone regardless of server location.
TIMEZONE=Asia/Tehran
